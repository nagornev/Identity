{
  "AllowedHosts": "*",

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "ConnectionStrings": {
    "ApplicationDbContext": "Data Source=localhost,5001;Initial Catalog=Identity;User ID=sa;Password=HHHHhhhh1111;TrustServerCertificate=True",
    "HangfireDbContext": "Host=localhost;Port=5002;Database=Scheduler;Username=sa;Password=HHHHhhhh1111"
  },

  "MessageBrokerOptions": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "mquser",
    "Password": "HHHHhhhh1111"
