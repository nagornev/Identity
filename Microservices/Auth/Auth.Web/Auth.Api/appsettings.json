  "ChannelTokenOptions": {
    "Lifetime": 3600 //1 hours
  },

  "AccessKeyOptions": {
    "Size": 2048,
    "TimeToLive": 604800, //7 days,
    "RotationInterval": "0 0 */5 * *" //every 5 days
  },

  "RefreshKeyOptions": {
    "Size": 2048,
    "TimeToLive": 2419200, //28 days,
    "RotationInterval": "0 0 */14 * *" //every 14 days
  },

  "ChannelKeyOptions": {
    "Size": 2048,
    "TimeToLive": 1209600, //14 days,
    "RotationInterval": "0 0 */7 * *" //every 7 days
  },

